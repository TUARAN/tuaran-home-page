# App URL / session
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# GitHub OAuth App (https://github.com/settings/developers)
GITHUB_ID=
GITHUB_SECRET=

# Google OAuth Client
GOOGLE_ID=
GOOGLE_SECRET=

# Owner allowlist, comma-separated. User ids are provider-prefixed, e.g. github:123456 or google:abc.
SITE_OWNER_IDS=
SITE_OWNER_LOGINS=
SITE_OWNER_EMAILS=

# Email login / registration codes
EMAIL_CODE_SECRET=
RESEND_API_KEY=
EMAIL_FROM=

# Cloudflare D1 binding name in Pages/Workers: DB
DB=

# Voice task API fallback token
VOICE_TASK_API_TOKEN=

# Optional distribution target used by research markdown export UI
NEXT_PUBLIC_SYNCBLOG_IMPORT_URL=

# 调研加密：标记 encrypted: true 的调研在构建期用此密码做 AES-256-GCM 加密。
# 本地放到 .env.local；线上在 Cloudflare Pages 构建环境变量里设置同一个值。
RESEARCH_ENCRYPTION_PASSWORD=
