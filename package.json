{
  "name": "tuaran-blog",
  "version": "1.0.0",
  "description": "TUARAN's personal blog homepage with modern design",
  "scripts": {
    "prepare": "node scripts/setup-hooks.mjs",
    "prebuild": "node scripts/check-public-asset-size.mjs && node scripts/generate-research-catalog.mjs",
    "dev": "next dev -p 3000",
    "build": "next build",
    "build:check": "NEXT_DIST_DIR=.next-check next build",
    "start": "next start -p 3000",
    "pages:build": "npx @cloudflare/next-on-pages@1.13.16",
    "pages:build:all": "npx @cloudflare/next-on-pages@1.13.16",
    "pages:build:public": "node scripts/build-public-pages.cjs",
    "lint": "next lint",
    "snapshot-memory": "node scripts/snapshot-memory.mjs"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.0",
    "@tabler/icons-react": "^3.44.0",
    "@tailwindcss/typography": "^0.5.10",
    "@tiptap/extension-character-count": "^3.27.1",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "echarts": "^6.1.0",
    "fast-xml-parser": "^5.9.3",
    "marked": "^14.1.4",
    "next": "^15.1.3",
    "next-themes": "^0.4.6",
    "pptxgenjs": "^4.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.184.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.56.0",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}
