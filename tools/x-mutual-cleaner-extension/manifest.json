{
  "manifest_version": 3,
  "name": "X Mutual Cleanup Assistant",
  "version": "0.1.10",
  "description": "Clean X non-mutual following accounts and test slow batch follow-back on follower lists.",
  "permissions": ["storage"],
  "host_permissions": ["https://x.com/*", "https://twitter.com/*"],
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
